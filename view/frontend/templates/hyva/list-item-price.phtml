<?php
/** @var Backendorf\Installment\Block\AllInstallments $block */

use Magento\Catalog\Model\Product;

$product = $block->getData('product');
if (!$product && $block->getParentBlock()) {
    $product = $block->getParentBlock()->getProduct();
}

if (!($product instanceof Product)) {
    $product = $block->getProduct();
}

if (!$product || !$product->getId()) {
    return;
}

// Get the final price reliably
$finalPrice = 0;
if ($product->getPriceInfo()) {
    $finalPrice = (float)$product->getPriceInfo()
        ->getPrice('final_price')
        ->getAmount()
        ->getValue();
} else {
    $finalPrice = (float)$product->getFinalPrice();
}

$fullActionName = $this->getRequest()->getFullActionName();

$template = match ($fullActionName) {
    'catalog_category_view' => 'catalog_category_view',
    'catalogsearch_result_index' => 'catalogsearch_result_index',
    'catalog_product_view' => 'catalog_product_view',
    default => 'catalog_category_view'
}
?>

<div x-defer="intersect"
     x-data="initInstallment(
        <?= (int)$product->getId() ?>,
        <?= $finalPrice ?>,
        '<?= $block->escapeHtml($template) ?>'
    )"
     x-init="init()"
     class="installments installments-hyva-list text-sm mt-1 min-h-[22px]"

     x-show="config.enabled && (bestInstallment || (discounts && discounts.length > 0))">

    <div class="best-installment price-installment" x-show="bestInstallment">
        <span x-html="renderBestInstallment()"></span>
    </div>

    <template x-if="discounts && discounts.length">
        <div class="discounts discounts-list text-xs leading-tight text-neutral-600 mt-1">
            <template x-for="discount in discounts" :key="discount.name">
                <div class="discount-item font-medium" x-html="renderDiscountItem(discount)"></div>
            </template>
        </div>
    </template>
</div>
